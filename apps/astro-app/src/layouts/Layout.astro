---
// The plugin exposes its output as a virtual module. `headTags` is the <link rel="preload"> list
// plus a <style> block with every @font-face and metric-matched fallback rule, already stringified.
// It is resolved at build time, so a prerendered page gets it baked into its .html file and an
// on-demand page gets it written into the response — same tags, same font URLs, either way.
import { headTags } from 'virtual:vite-font'

interface Props {
  title: string
  mode: string
  blurb: string
}

const { title, mode, blurb } = Astro.props
const path = Astro.url.pathname
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <Fragment set:html={headTags} />
  </head>
  <body>
    <main>
      <nav>
        <a href="/" class:list={[{ active: path === '/' }]}>Prerendered</a>
        <a href="/live" class:list={[{ active: path === '/live' }]}>On demand</a>
      </nav>

      <header>
        <p class="eyebrow">{mode}</p>
        <h1>{title}</h1>
        <p class="lede">{blurb}</p>
      </header>

      <slot />

      <footer>
        <p>
          Both routes pull their fonts from the same <code>virtual:vite-font</code> module. The
          <code>@font-face</code> rules and preload links live in the <code>&lt;head&gt;</code> of each, and the local Gabarito files are served from a content-hashed URL under <code
            >/assets/vite-font/</code
          > that was emitted into the build.
        </p>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #ffffff;
    --fg: #16161a;
    --muted: #6b6b76;
    --line: #e6e6ea;
    --accent: #5b4ef7;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0e0e11;
      --fg: #f2f2f5;
      --muted: #9a9aa6;
      --line: #26262d;
      --accent: #a49bff;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    -webkit-font-smoothing: antialiased;
  }

  main {
    max-width: 44rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  nav {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 3.5rem;
  }

  nav a {
    font-family: var(--jetbrains);
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.375rem 0.875rem;
  }

  nav a.active {
    color: var(--bg);
    background: var(--fg);
    border-color: var(--fg);
  }

  .eyebrow {
    font-family: var(--jetbrains);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1rem;
  }

  h1 {
    font-family: var(--fraunces);
    font-weight: 600;
    font-size: clamp(2.25rem, 6vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }

  .lede {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  section {
    margin-top: 3.5rem;
    display: grid;
    gap: 2.5rem;
  }

  article {
    padding-top: 2.5rem;
    border-top: 1px solid var(--line);
  }

  article:first-child {
    padding-top: 0;
    border-top: 0;
  }

  h2 {
    font-family: var(--fraunces);
    font-weight: 900;
    font-size: 1.375rem;
    margin: 0 0 0.5rem;
  }

  article p {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .sample {
    margin: 1.5rem 0 0;
    font-size: 1.75rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .stamp {
    font-family: var(--jetbrains);
    font-size: 0.9375rem;
    color: var(--fg);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin-top: 2.5rem;
  }

  footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--muted);
  }

  footer p {
    margin: 0;
  }

  code {
    font-family: var(--jetbrains);
    font-size: 0.875em;
    color: var(--fg);
  }
</style>
